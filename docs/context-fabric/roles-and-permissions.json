    },
    {
      "resource": "catalog-details",
      "operation": "view",
      "required_roles": ["Anonymous", "Authenticated"],
      "page": "Catalog/Details.aspx",
      "route": "/Catalog/Details/{id}"
    },
    {
      "resource": "catalog-item",
      "operation": "create",
      "required_roles": ["Authenticated"],
      "page": "Catalog/Create.aspx",
      "route": "/Catalog/Create",
      "enforcement": "OpenID Connect challenge redirect"
    },
    {
      "resource": "catalog-item",
      "operation": "update",
      "required_roles": ["Authenticated"],
      "page": "Catalog/Edit.aspx",
      "route": "/Catalog/Edit/{id}",
      "enforcement": "OpenID Connect challenge redirect"
    },
    {
      "resource": "catalog-item",
      "operation": "delete",
      "required_roles": ["Authenticated"],
      "page": "Catalog/Delete.aspx",
      "route": "/Catalog/Delete/{id}",
      "enforcement": "OpenID Connect challenge redirect"
    },
    {
      "resource": "product-image",
      "operation": "upload",
      "required_roles": ["Anonymous"],
      "page": "Catalog/PicUploader.asmx",
      "route": "/Catalog/PicUploader.asmx",
      "note": "Image upload service has no authentication - potential security issue"
    }
  ],
  "access_control_implementation": {
    "type": "Page-level checks",
    "mechanism": "Page_Load event handler checks Request.IsAuthenticated",
    "challenge_method": "Context.GetOwinContext().Authentication.Challenge",
    "redirect_after_auth": "RedirectUri property in AuthenticationProperties"
  },
  "role_storage": {
    "provider": "Azure Active Directory",
    "local_storage": "None (no local user/role tables)",
    "session_management": "ASP.NET session state (optional Redis)"
  },
  "permission_boundaries": {
    "read_operations": {
      "public": true,
      "pages": ["Default.aspx", "Catalog/Details.aspx"],
      "rationale": "E-commerce catalog should be publicly viewable"
    },
    "write_operations": {
      "public": false,
      "pages": ["Catalog/Create.aspx", "Catalog/Edit.aspx", "Catalog/Delete.aspx"],
      "rationale": "Only authenticated users can modify catalog"
    }
  },
  "seam_suggestions": {
    "catalog-management-read": {
      "operations": ["list", "details"],
      "required_roles": ["Anonymous"],
      "complexity": "low",
