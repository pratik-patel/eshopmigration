{
  "database": {
    "type": "SQL Server",
    "orm": "Entity Framework 6",
    "context": "CatalogDBContext",
    "connection_string_source": "Configuration (Web.config or Azure KeyVault)"
  },
  "tables": [
    {
      "name": "Catalog",
      "entity": "CatalogItem",
      "purpose": "Stores product catalog items",
      "columns": [
        {
          "name": "Id",
          "type": "int",
          "nullable": false,
          "primary_key": true,
          "generated": "HiLo sequence (catalog_hilo)"
        },
        {
          "name": "Name",
          "type": "nvarchar(50)",
          "nullable": false
        },
        {
          "name": "Description",
          "type": "nvarchar(max)",
          "nullable": true
        },
        {
          "name": "Price",
          "type": "decimal(18,2)",
          "nullable": false
        },
        {
          "name": "PictureFileName",
          "type": "nvarchar(max)",
          "nullable": false,
          "default": "dummy.png"
        },
        {
          "name": "CatalogTypeId",
          "type": "int",
          "nullable": false,
          "foreign_key": "CatalogType.Id"
        },
        {
          "name": "CatalogBrandId",
          "type": "int",
          "nullable": false,
          "foreign_key": "CatalogBrand.Id"
        },
        {
          "name": "AvailableStock",
          "type": "int",
          "nullable": false,
          "description": "Quantity in stock"
        },
        {
          "name": "RestockThreshold",
          "type": "int",
          "nullable": false,
          "description": "Available stock at which we should reorder"
        },
        {
          "name": "MaxStockThreshold",
          "type": "int",
          "nullable": false,
          "description": "Maximum number of units that can be in-stock"
        },
        {
          "name": "OnReorder",
          "type": "bit",
          "nullable": false,
          "description": "True if item is on reorder"
        }
      ],
      "indexes": [
        {
          "name": "PK_Catalog",
          "type": "PRIMARY KEY",
          "columns": ["Id"]
        }
      ],
      "foreign_keys": [
        {
          "name": "FK_Catalog_CatalogBrand",
          "column": "CatalogBrandId",
          "references": "CatalogBrand(Id)",
          "on_delete": "NO ACTION"
        },
        {
          "name": "FK_Catalog_CatalogType",
          "column": "CatalogTypeId",
          "references": "CatalogType(Id)",
          "on_delete": "NO ACTION"
        }
      ]
    },
    {
      "name": "CatalogBrand",
      "entity": "CatalogBrand",
      "purpose": "Lookup table for product brands",
      "columns": [
        {
          "name": "Id",
          "type": "int",
          "nullable": false,
          "primary_key": true,
          "generated": "HiLo sequence (catalog_brand_hilo)"
        },
        {
          "name": "Brand",
          "type": "nvarchar(100)",
          "nullable": false
        }
      ],
      "indexes": [
        {
          "name": "PK_CatalogBrand",
          "type": "PRIMARY KEY",
          "columns": ["Id"]
        }
      ]
    },
    {
      "name": "CatalogType",
      "entity": "CatalogType",
      "purpose": "Lookup table for product types/categories",
      "columns": [
        {
          "name": "Id",
          "type": "int",
          "nullable": false,
          "primary_key": true,
          "generated": "HiLo sequence (catalog_type_hilo)"
        },
        {
          "name": "Type",
          "type": "nvarchar(100)",
          "nullable": false
        }
      ],
      "indexes": [
        {
          "name": "PK_CatalogType",
          "type": "PRIMARY KEY",
          "columns": ["Id"]
        }
      ]
    }
  ],
  "sequences": [
    {
      "name": "catalog_hilo",
      "purpose": "HiLo ID generation for Catalog table",
      "start_value": 1,
      "increment": 10
    },
    {
      "name": "catalog_brand_hilo",
      "purpose": "HiLo ID generation for CatalogBrand table",
      "start_value": 1,
      "increment": 10
    },
    {
      "name": "catalog_type_hilo",
      "purpose": "HiLo ID generation for CatalogType table",
      "start_value": 1,
      "increment": 10
    }
  ],
  "relationships": [
    {
      "type": "one-to-many",
      "parent": "CatalogBrand",
      "child": "Catalog",
      "description": "Each brand can have multiple catalog items"
    },
    {
      "type": "one-to-many",
      "parent": "CatalogType",
      "child": "Catalog",
      "description": "Each type can have multiple catalog items"
    }
  ],
  "seed_data": {
    "location": "Models/Infrastructure/PreconfiguredData.cs",
    "description": "Database initializer seeds sample brands, types, and catalog items"
  }
}
