{
  "framework": "ASP.NET WebForms",
  "language": "C#",
  "target_framework": ".NET Framework 4.6+",
  "solution_file": "C:\\Users\\pratikp6\\codebase\\eShopModernizing\\eShopModernizedWebFormsSolution\\eShopModernizedWebForms.sln",
  "application_root": "C:\\Users\\pratikp6\\codebase\\eShopModernizing\\eShopModernizedWebFormsSolution\\src\\eShopModernizedWebForms",
  "runtime_url": "http://localhost:50586",
  "entry_points": [
    {
      "path": "Default.aspx",
      "purpose": "Catalog list page - main entry point",
      "authentication_required": false
    },
    {
      "path": "Catalog/Create.aspx",
      "purpose": "Create new catalog item",
      "authentication_required": true
    },
    {
      "path": "Catalog/Edit.aspx",
      "purpose": "Edit existing catalog item",
      "authentication_required": true
    },
    {
      "path": "Catalog/Details.aspx",
      "purpose": "View catalog item details",
      "authentication_required": false
    },
    {
      "path": "Catalog/Delete.aspx",
      "purpose": "Delete catalog item",
      "authentication_required": true
    }
  ],
  "data_access": {
    "orm": "Entity Framework 6",
    "db_context": "CatalogDBContext",
    "connection_type": "SQL Server",
    "tables": [
      "Catalog",
      "CatalogBrand",
      "CatalogType"
    ]
  },
  "services": [
    {
      "interface": "ICatalogService",
      "implementation": "CatalogService",
      "purpose": "Business logic for catalog operations"
    },
    {
      "interface": "IImageService",
      "implementations": [
        "ImageAzureStorage",
        "ImageMockStorage"
      ],
      "purpose": "Image storage abstraction (Azure or local)"
    }
  ],
  "authentication": {
    "type": "OpenID Connect",
    "library": "Microsoft.Owin.Security.OpenIdConnect",
    "requirement": "Required for Create, Edit, Delete operations"
  },
  "dependencies": [
    "Entity Framework 6.3.0",
    "log4net",
    "Autofac (DI container)",
    "Microsoft.Owin.Security.OpenIdConnect",
    "Azure Storage SDK (optional)"
  ],
  "architecture_notes": {
    "pattern": "Traditional 3-tier: UI (ASPX) -> Service Layer -> Data Layer (EF)",
    "dependency_injection": "Autofac container configured in Global.asax",
    "pagination": "Server-side pagination with configurable page size",
    "image_handling": "Azure Blob Storage or local file system based on configuration"
  }
}
