# Environment
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite+aiosqlite:///./eshop_catalog.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:pass@localhost/eshop_catalog

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Mock data mode (set to false to use real database)
USE_MOCK_ADAPTERS=true

# Logging
LOG_LEVEL=INFO
